system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif; }\n    a { color: inherit; text-decoration: none; }\n    .orv {\n      --bg:#f7f2ea; --panel:#ffffff; --panel2:#fbf8f2; --border:#ece6dc;\n      --text:#1c1712; --muted:#928a7e; --faint:#b6ada0;\n      --accent:#ec5b1a; --accent2:#f5843b;\n      --green:#2e9e5b; --red:#e0574a; --blue:#6f8fd0; --amber:#e6a92f;\n      --sidebar:#ffffff; --shadow:0 1px 2px rgba(28,23,18,.04), 0 8px 24px rgba(28,23,18,.05);\n    }\n    .orv[data-theme=\"dark\"] {\n      --bg:#0c0c10; --panel:#16161c; --panel2:#1b1b22; --border:#26262f;\n      --text:#f3f1ee; --muted:#8f8a83; --faint:#5c5850;\n      --accent:#ff6a2c; --accent2:#ff8a4d;\n      --green:#4ec27f; --red:#f0705f; --blue:#7fa0e6; --amber:#efc158;\n      --sidebar:#111116; --shadow:0 1px 2px rgba(0,0,0,.4), 0 10px 30px rgba(0,0,0,.35);\n    }\n    .orv[data-accent=\"rose\"]{ --accent:#e0567a; --accent2:#ef7d99; }\n    .orv[data-accent=\"teal\"]{ --accent:#0f9d8f; --accent2:#33b6a9; }\n    .orv ::-webkit-scrollbar{ width:8px; height:8px; }\n    .orv ::-webkit-scrollbar-thumb{ background:color-mix(in srgb, var(--muted) 40%, transparent); border-radius:8px; }\n  <\u002Fstyle>\n<\u002Fhelmet>\n\n<section style=\"display:flex; flex-wrap:wrap; gap:64px; padding:60px; background:#e9e4db; align-items:flex-start;\">\n\n  <!-- ============ OPTION 1a — WARM CLASSIC ============ -->\n  <div id=\"1a\" style=\"position:relative;\">\n    <div style=\"position:absolute; top:-34px; left:0; display:flex; align-items:center; gap:10px;\">\n      <span style=\"background:#1c1712; color:#fff; font-size:13px; font-weight:700; padding:4px 12px; border-radius:20px;\">1a<\u002Fspan>\n      <span style=\"color:#6b6459; font-size:13px; font-weight:600;\">Warm Classic<\u002Fspan>\n    <\u002Fdiv>\n\n    <div class=\"orv\" data-theme=\"{{ themeA }}\" data-accent=\"{{ accent }}\" style=\"width:1280px; height:900px; display:flex; background:var(--bg); border-radius:22px; overflow:hidden; box-shadow:0 30px 80px rgba(0,0,0,.18); color:var(--text);\">\n\n      <!-- Sidebar -->\n      <aside style=\"width:236px; flex-shrink:0; background:var(--sidebar); border-right:1px solid var(--border); display:flex; flex-direction:column; padding:22px 16px;\">\n        <div style=\"display:flex; align-items:center; gap:10px; padding:4px 8px 22px;\">\n          <div style=\"width:34px; height:34px; border-radius:10px; background:var(--accent); display:flex; align-items:center; justify-content:center; color:#fff; font-weight:800; font-size:16px;\">O<\u002Fdiv>\n          <span style=\"font-size:16px; font-weight:800; letter-spacing:-.3px;\">orendezvous<\u002Fspan>\n        <\u002Fdiv>\n\n        <div style=\"font-size:10px; font-weight:700; letter-spacing:1.2px; color:var(--faint); padding:14px 10px 8px;\">OPÉRATION<\u002Fdiv>\n        <a href=\"#\" style=\"display:flex; align-items:center; gap:11px; padding:10px 11px; border-radius:11px; background:color-mix(in srgb, var(--accent) 12%, transparent); color:var(--accent); font-size:13.5px; font-weight:700;\">\n          <svg width=\"17\" height=\"17\" sc-camel-view-box=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1.5\"><\u002Frect><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1.5\"><\u002Frect><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1.5\"><\u002Frect><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1.5\"><\u002Frect><\u002Fsvg>\n          Aperçu\n        <\u002Fa>\n        <a href=\"#\" style=\"display:flex; align-items:center; gap:11px; padding:10px 11px; border-radius:11px; color:var(--muted); font-size:13.5px; font-weight:600;\">\n          <svg width=\"17\" height=\"17\" sc-camel-view-box=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z\"><\u002Fpath><path d=\"M3 6h18\"><\u002Fpath><path d=\"M16 10a4 4 0 0 1-8 0\"><\u002Fpath><\u002Fsvg>