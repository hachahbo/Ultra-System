# Supabase Configuration (Used in Next.js App Router)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Airtable Configuration (If still using legacy Expo/Airtable sync)
EXPO_PUBLIC_AIRTABLE_BASE_ID=your-base-id
EXPO_PUBLIC_AIRTABLE_API_KEY=your-airtable-api-key

# Optional: point the client at a separate API host (blank = same origin).
# EXPO_PUBLIC_API_BASE_URL=

# ── Server ONLY (never prefixed EXPO_PUBLIC — must NOT reach the browser) ─────
# AIRTABLE_TOKEN must be a SEPARATE, WRITE-scoped PAT (data.records:read+write).
AIRTABLE_TOKEN=your-airtable-token
AIRTABLE_BASE_ID=your-base-id
# Secret used to sign dashboard auth tokens. Replace with a long random string.
AUTH_SECRET=dev-only-change-me-to-a-long-random-string

passsubabase=your-password
SUPABASE_Tokens=your-supabase-token

# Dashboard/Auth
AUTH_SECRET="generate-a-long-random-string-here"
